# ─────────────────────────────────────────────────────────────
# Social Connect — Backend environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Core ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/socialconnect
JWT_SECRET=replace-with-a-strong-random-32+-char-secret
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-32+-char-secret
FRONTEND_URL=http://localhost:5173
PORT=4000
NODE_ENV=development

# --- Redis (optional) ---
# Leave empty to run without caching. In production use the internal URL of a
# managed Redis / Key Value instance in the same region.
REDIS_URL=

# --- Keep-warm (optional) ---
# Set to "true" on a free-tier host to self-ping /health and avoid cold starts.
KEEP_WARM=

# --- Admin account (optional) ---
# If both are set, an admin user is seeded on startup. If unset, seeding is
# skipped. Use a strong, unique password — do not reuse a real personal one.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_USERNAME=admin

# --- Cloudinary (optional, for media uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# --- Email / SMTP (optional, for OTP & password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Public asset URL (optional) ---
# Base URL used to build absolute links to uploaded assets. On Render this is
# provided automatically via RENDER_EXTERNAL_URL.
API_PUBLIC_URL=
