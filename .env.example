# Local development
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/socialconnect
JWT_SECRET=change-me-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
FRONTEND_URL=http://localhost:5173
PORT=4000
NODE_ENV=development

# Production (Render) — set these in Render dashboard Environment tab:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@sc.iudyjxq.mongodb.net/socialconnect?appName=sc
# FRONTEND_URL=https://social-connect-frontend-pi.vercel.app
# NODE_ENV=production
# JWT_SECRET=<strong-random-32+-char-secret>
# JWT_REFRESH_SECRET=<strong-random-32+-char-secret>
# REDIS_URL=redis://red-xxxxxxxxxxxxxxxxxxxx:6379

# Optional locally. In production, use the internal URL of a Render Key Value
# instance in the same workspace and region. The API works without Redis.
REDIS_URL=

# Set to "true" on Render free tier to self-ping /health every 14 min and avoid
# cold starts. Requires RENDER_EXTERNAL_URL (set automatically by Render).
KEEP_WARM=

# Admin panel login (seeded on server start)
ADMIN_EMAIL=vijaynarkar17@gmail.com
ADMIN_PASSWORD=12345678
ADMIN_USERNAME=admin

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
